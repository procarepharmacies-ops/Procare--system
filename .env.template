# ALERT THRESHOLDS
ALERT_EXPIRY_DAYS=60
ALERT_LOW_STOCK_DAYS=7

# BRANCHES
BRANCH_MAIN=Elsanta
BRANCH_SECOND=Mashala

# LANGUAGE & DISPLAY
