# ── ProCare Pharmacy Intelligence System Configuration ──
# Copy this file to .env and fill in the actual values

# SQL SERVER CONFIGURATION
SQL_SERVER=DESKTOP-3A9JFL4
SQL_DATABASE=stock
SQL_USERNAME=
SQL_PASSWORD=
SQL_DRIVER={ODBC Driver 17 for SQL Server}

# SLACK CONFIGURATION
# 1. Create a Slack Bot at https://api.slack.com/apps
# 2. Add scopes: chat:write, chat:write.public
# 3. Copy the Bot User OAuth Token here
